<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <!-- 应用标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="找回密码"
        android:fontFamily="@font/yuanshen"
        android:textSize="24sp"
        android:textColor="@color/green"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <!-- 用户名输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/usernameLayout"
        android:layout_width="match_parent"
        android:fontFamily="@font/yuanshen"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="手机号">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:imeOptions="actionNext"
            android:nextFocusDown="@+id/passwordInput"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/yanzhengmaLayout"
            android:layout_width="wrap_content"
            android:fontFamily="@font/yuanshen"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="验证码">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/yanzhengmaInput"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:imeOptions="actionNext"
                android:nextFocusDown="@+id/passwordInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/identity_text"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/green"
            android:text="发送验证码"
            android:fontFamily="@font/yuanshen"
            android:textColor="@color/white"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- 密码输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordLayout"
        android:layout_width="match_parent"
        android:fontFamily="@font/yuanshen"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="密码">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:imeOptions="actionNext"
            android:nextFocusDown="@+id/confirmPasswordInput"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 确认密码输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/confirmPasswordLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/yuanshen"
        android:layout_marginBottom="24dp"
        android:hint="确认密码">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/confirmPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/registerButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/yuanshen"
        android:text="确认"
        android:backgroundTint="@color/green"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/yuanshen"
        android:text="返回"
        android:backgroundTint="@color/green"
        android:textColor="@color/white" />

</LinearLayout>
